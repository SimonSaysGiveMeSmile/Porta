FROM golang:1.25-alpine AS build
WORKDIR /src
COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend ./
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/porta ./cmd/porta

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=build /out/porta /app/porta
COPY --from=build /src/internal/storage/migrations /app/migrations
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/app/porta"]
