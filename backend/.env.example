PORTA_ADDR=:8080
PORTA_ENV=dev
PORTA_DATABASE_URL=postgres://porta:porta@localhost:5432/porta?sslmode=disable
PORTA_PUBLIC_BASE_URL=http://localhost:8080
PORTA_SHARE_HMAC_SECRET=dev-share-hmac-change-me-to-32-bytes-min
PORTA_JWT_SECRET=dev-jwt-secret-change-me-to-32-bytes-minimum
PORTA_JWT_TTL_MINUTES=30
PORTA_SHARE_TTL_HOURS=24

# APNS (leave empty in dev — push will be stubbed and logged)
PORTA_APNS_KEY_PATH=
PORTA_APNS_KEY_ID=
PORTA_APNS_TEAM_ID=
PORTA_APNS_BUNDLE_ID=app.porta.ios
PORTA_APNS_SANDBOX=true
